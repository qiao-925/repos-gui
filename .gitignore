# 忽略系统文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 忽略 Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 忽略 Python 包元数据（pip install -e . 自动生成）
*.egg-info/
build/
dist/

# 忽略 PyInstaller 构建产物
*.spec

# 忽略 Claude Code 配置
.claude/
.codex/

# AI 工具配置（可选：通过 scripts/sync-agent-rules.py 从 docs/agent-rules/ 生成）
# 注意：AGENTS.md 是通用入口，工具特定配置不是必需的
.cursor/

# Handoff 历史归档（运行产物，按轮次存档但不跟踪）
handoff/history/

# Agent rules sync config（由 Cursor 自动生成，脚本不依赖）
.agent-rules-config.json

# 忽略 uv 虚拟环境
.venv/

repos
tmp-clonex-smoke/

failed-repos.txt

# 私有配置文件
REPO-GROUPS.md

# 运行时数据
logs/
.auto_gist_settings.json
.gist_cache/

# AI 会话记录（不入库）
conversation-*.md

# pytest
.pytest_cache/
.pytest-tmp/
